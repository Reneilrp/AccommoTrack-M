erDiagram
    USERS ||--|| LANDLORD_PROFILES : "has"
    USERS ||--|| TENANT_PROFILES : "has"
    USERS ||--o{ PROPERTIES : "owns" 
    USERS ||--o{ BOOKINGS : "makes/receives" 
    USERS ||--o{ MESSAGES : "sends/receives" 
    USERS ||--o{ CARETAKER_ASSIGNMENTS : "manages" 
