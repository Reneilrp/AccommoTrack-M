    USERS ||--o{ PAYMENTS : "pays" 
    USERS ||--o{ LANDLORD_VERIFICATIONS : "submits/reviews" 

    USERS {
        BIGINT id PK
        ENUM role "landlord, tenant, admin, caretaker"
        VARCHAR-255 email
        VARCHAR-255 password
        VARCHAR-100 remember_token
        JSON notification_preferences
        VARCHAR-100 first_name
        VARCHAR-100 middle_name
        VARCHAR-100 last_name
        VARCHAR-20 phone
        VARCHAR-255 profile_image
        TINYINT-1 is_verified
        TINYINT-1 is_active
        JSON payment_methods_settings
        TINYINT-1 is_blocked
        VARCHAR-255 paymongo_child_id
        VARCHAR-255 paymongo_verification_status
    }

    LANDLORD_PROFILES {
        BIGINT id PK
        BIGINT user_id FK
        VARCHAR-255 business_name
        TEXT address
        VARCHAR-255 barangay
        VARCHAR-100 city
        VARCHAR-20 postal_code
        ENUM verification_status "pending, verified, rejected"
    }

    TENANT_PROFILES {
        BIGINT id PK
        BIGINT user_id FK
        DATE move_in_date
        DATE move_out_date
        ENUM status "active, inactive, evicted"
        BIGINT booking_id
        TEXT notes
        VARCHAR-255 emergency_contact_name
        VARCHAR-20 emergency_contact_phone
        VARCHAR-100 emergency_contact_relationship
        TEXT current_address
        JSON preference
        DATE date_of_birth
        VARCHAR-20 gender
    }

    PROPERTIES ||--o{ ROOMS : "contains" 
    PROPERTIES ||--o{ PROPERTY_IMAGES : "has" 
    PROPERTIES ||--o{ PROPERTY_CREDENTIALS : "has" 
    PROPERTIES ||--o{ REPORTS : "reported_in" 
    PROPERTIES ||--o{ ADDONS : "offers" 

    PROPERTIES {
        BIGINT id PK
        BIGINT landlord_id FK
        VARCHAR-255 title
        TEXT description
        ENUM property_type "dormitory, apartment, boardingHouse, bedSpacer, others"
        ENUM current_status "active, inactive, pending, maintenance, draft"
        VARCHAR-255 street_address
        VARCHAR-100 city
        VARCHAR-100 province
        VARCHAR-20 postal_code
        VARCHAR-100 country
        VARCHAR-100 barangay
        DECIMAL-10-7 latitude
        DECIMAL-10-7 longitude
        TEXT nearby_landmarks
        TEXT property_rules
        INT total_rooms
        INT available_rooms
        TINYINT-1 is_published
        TINYINT-1 is_available
        TINYINT-1 is_eligible
        JSON accepted_payments
    }

    PROPERTY_IMAGES {
        BIGINT id PK
        BIGINT property_id FK
        VARCHAR-255 image_url
        VARCHAR-255 media_type
        TINYINT-1 is_primary
        INT display_order
    }

    PROPERTY_CREDENTIALS {
        BIGINT id PK
        BIGINT property_id FK
        VARCHAR-255 file_path
        VARCHAR-255 original_name
        VARCHAR-255 mime
    }

    ROOMS ||--o{ ROOM_IMAGES : "has" 
    ROOMS ||--o{ ROOM_TENANT_ASSIGNMENTS : "manages_occupancy" 

    ROOMS {
        BIGINT id PK
        BIGINT property_id FK
        VARCHAR-50 room_number
        ENUM room_type "single, double, quad, bedSpacer"
        INT floor
        DECIMAL-10-2 monthly_rate
        DECIMAL-10-2 daily_rate
        ENUM billing_policy "monthly, monthly_with_daily, daily"
        INT capacity
        ENUM pricing_model "full_room, per_bed"
        ENUM status "available, occupied, maintenance"
        BIGINT current_tenant_id FK
        TEXT description
    }

    ROOM_TENANT_ASSIGNMENTS {
        BIGINT id PK
        BIGINT room_id FK
        BIGINT tenant_id FK
        DATE start_date
        DATE end_date
        DECIMAL-10-2 monthly_rent
        ENUM status "active, ended, cancelled"
        DECIMAL-10-2 deposit_amount
        TEXT notes
    }

    BOOKINGS ||--o{ BOOKING_ADDONS : "includes" 
    BOOKINGS ||--o{ INVOICES : "generates" 
    BOOKINGS ||--o{ PAYMENTS : "receives" 
    
    BOOKINGS {
        BIGINT id PK
        BIGINT property_id FK
        BIGINT room_id FK
        BIGINT tenant_id FK
        BIGINT landlord_id FK
        VARCHAR-255 guest_name
        VARCHAR-50 booking_reference
        DATE start_date
        DATE end_date
        INT total_months
        DECIMAL-10-2 monthly_rent
        DECIMAL-10-2 total_amount
        DECIMAL-10-2 refund_amount
        TIMESTAMP refund_processed_at
        ENUM status "pending, confirmed, cancelled, completed, partial-completed"
        ENUM payment_status "unpaid, partial, paid, refunded"
        VARCHAR-255 payment_method
        TEXT notes
        TEXT cancellation_reason
    }

    ADDONS ||--o{ BOOKING_ADDONS : "added_via" 

    ADDONS {
        BIGINT id PK
        BIGINT property_id FK
        VARCHAR-255 name
        TEXT description
        DECIMAL-10-2 price
        ENUM price_type "one_time, monthly"
        ENUM addon_type "rental, fee"
        INT stock
        TINYINT-1 is_active
    }

    BOOKING_ADDONS {
        BIGINT id PK
        BIGINT booking_id FK
        BIGINT addon_id FK
        INT quantity
        DECIMAL-10-2 price_at_booking
        ENUM status "pending, approved, active, rejected, completed, cancelled"
        TEXT request_note
        TEXT response_note
        TIMESTAMP approved_at
        BIGINT approved_by FK
        TIMESTAMP invoiced_at
        BIGINT invoice_id FK
    }

    PAYMENTS {
        BIGINT id PK
        BIGINT tenant_id FK
        BIGINT room_id FK
        BIGINT booking_id FK
        DECIMAL-10-2 amount
        DATE payment_date
        DATE due_date
        ENUM status "paid, pending, overdue, cancelled"
        ENUM payment_method "cash, bank_transfer, gcash, paymaya, card"
        VARCHAR-100 reference_number
        TEXT notes
    }

    INVOICES ||--o{ PAYMENT_TRANSACTIONS : "recorded_by" 

    INVOICES {
        BIGINT id PK
        VARCHAR-255 reference
        BIGINT landlord_id FK
        BIGINT property_id FK
        BIGINT booking_id FK
        BIGINT tenant_id FK
        TEXT description
        INT subtotal_cents
        INT tax_cents
        DECIMAL-5-2 tax_percent
        INT total_cents
        INT amount_cents
        VARCHAR-3 currency
        VARCHAR-255 status
        DATE due_date
        TIMESTAMP issued_at
        TIMESTAMP paid_at
        JSON metadata
    }

    PAYMENT_TRANSACTIONS {
        BIGINT id PK
        BIGINT invoice_id FK
        BIGINT tenant_id FK
        INT amount_cents
        INT gateway_fee_cents
        INT net_amount_cents
        VARCHAR-3 currency
        VARCHAR-255 status
        VARCHAR-255 method
        VARCHAR-255 gateway_reference
        VARCHAR-255 balance_transaction_id
        JSON gateway_response
        VARCHAR-255 idempotency_key
        VARCHAR-255 provider_event_id
        INT refunded_amount_cents
    }

    REPORTS {
        BIGINT id PK
        BIGINT reporter_id FK
        BIGINT property_id FK
        VARCHAR-255 reason
        TEXT description
        ENUM status "pending, resolved, dismissed"
        TEXT admin_notes
    }

    LANDLORD_VERIFICATIONS ||--o{ LANDLORD_VERIFICATION_HISTORY : "tracks" 

    LANDLORD_VERIFICATIONS {
        BIGINT id PK
        BIGINT user_id FK
        VARCHAR-255 first_name
        VARCHAR-255 middle_name
        VARCHAR-255 last_name
        VARCHAR-255 valid_id_type
        VARCHAR-255 valid_id_other
        VARCHAR-255 valid_id_path
        VARCHAR-255 permit_path
        ENUM status "pending, approved, rejected"
        TEXT rejection_reason
        TIMESTAMP reviewed_at
        BIGINT reviewed_by FK
    }

    LANDLORD_VERIFICATION_HISTORY {
        BIGINT id PK
        BIGINT landlord_verification_id FK
        VARCHAR-255 valid_id_type
        VARCHAR-255 valid_id_other
        VARCHAR-255 valid_id_path
        VARCHAR-255 permit_path
        ENUM status "pending, approved, rejected"
        TEXT rejection_reason
        TIMESTAMP submitted_at
        TIMESTAMP reviewed_at
        BIGINT reviewed_by FK
    }

    CARETAKER_ASSIGNMENTS ||--o{ CARETAKER_PROPERTY_ASSIGNMENTS : "assigns_to" 

    CARETAKER_ASSIGNMENTS {
        BIGINT id PK
        BIGINT landlord_id FK
        BIGINT caretaker_id FK
        TINYINT-1 can_view_bookings
        TINYINT-1 can_view_messages
        TINYINT-1 can_view_tenants
        TINYINT-1 can_view_rooms
        TINYINT-1 can_view_properties
    }

    CARETAKER_PROPERTY_ASSIGNMENTS {
        BIGINT id PK
        BIGINT caretaker_assignment_id FK
        BIGINT property_id FK
    }

    MESSAGES {
        BIGINT id PK
        BIGINT conversation_id FK
        BIGINT sender_id FK
        BIGINT actual_sender_id FK
        VARCHAR-20 sender_role
        BIGINT receiver_id FK
        BIGINT room_id FK
        TEXT message
        VARCHAR-255 image_url
        TINYINT-1 is_read
        TIMESTAMP read_at
    }